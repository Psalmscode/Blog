<div class="author">
    <div>
        <h1 class="author_heading">Hi, I'm Wonder</h1>
        <p class="author_body">Welcome to my blog. I write about web development, programming, and modern technologies.</p>
    </div>
    <img src="/img/Wonder_Image_ob57loob57loob57.png" alt="Wonder - Blog Author" class="hero-image">
</div>

<% if (user) { %>
    <div class="login-info" style="text-align:right; margin:10px 0;">
        <span>Logged in as <strong><%= user.username %></strong></span>
        <% if (user.userType === 'admin') { %>
            (<a href="/admin/dashboard">Admin Dashboard</a>)
        <% } %>
        | <a href="/logout" style="color:#007bff;">Logout</a>
    </div>
<% } %>

<section class="articles">
    <h2 class="articles_heading">Latest Posts</h2>

   <ul class="article-ul">
    <% if (data && data.length > 0) { %>
        <% data.forEach(Post => { %>
            <li>
                <a href="/post/<%= Post._id %>">
                    <span><%= Post.title %></span>
                    <span class="article-list_date"><%= Post.createdAt ? Post.createdAt.toDateString() : 'No Date' %></span>
                </a>
                <% if (user && (user.userType==='admin' || user.userId==Post.userId)) { %>
                    <span class="post-actions">
                        <% if (user.userType==='admin') { %>
                            <form method="POST" action="/admin/delete-post/<%= Post._id %>?_method=DELETE" style="display:inline">
                                <button class="small danger">Delete</button>
                            </form>
                        <% } %>

                        <a href="<%= user.userType==='admin' ? '/admin/edit-post/'+Post._id : '/user/edit-post/'+Post._id %>" class="small">Edit</a>
                        
                        <% if (user.userType==='user') { %>
                            <form method="POST" action="/user/delete-post/<%= Post._id %>?_method=DELETE" style="display:inline">
                                <button class="small danger">Delete</button>
                            </form>
                        <% } %>
                    </span>
                <% } %>
            </li>
        <% }) %>
    <% } else { %>
        <p>No posts found. Create one using your /api/test route!</p>
    <% } %>
</ul>

<% if (nextPage !== null) { %>
    <a href="/?page=<%= nextPage %>" class="pagination">View Newer Posts &gt;</a>
<% } %>

</section>