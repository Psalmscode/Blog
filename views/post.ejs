<article class="article-post">
    <h1 class="article-post_title"><%= data.title %></h1>
    
    <div class="article-post_body">
        <%- data.content.replace(/\n\n/g, '</p><p>').replace(/\n/g, '<br>').replace(/^/, '<p>').replace(/$/, '</p>') %>
    </div>
    
    <% if (data.createdAt) { %>
        <div class="article-post_date">
            <p>Published on <%= data.createdAt.toDateString() %></p>
        </div>
    <% } %>
</article>

<% if (user && (user.userType==='admin' || user.userId==data.userId)) { %>
  <div class="post-actions">
    <a href="<%= user.userType==='admin'
                ? '/admin/edit-post/'+data._id
                : '/user/edit-post/'+data._id %>"
       class="btn">Edit</a>

    <form method="POST"
          action="<%= user.userType==='admin'
                     ? '/admin/delete-post/'+data._id+'?_method=DELETE'
                     : '/user/delete-post/'+data._id+'?_method=DELETE' %>"
          style="display:inline">
      <button class="btn danger">Delete</button>
    </form>
  </div>
<% } %>

<a href="/" class="back-link">← Back to Posts</a>