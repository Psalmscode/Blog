<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css">
<header class="header">
    <a href="/" class="header_logo">Nodejs</a>

    <nav class="header_nav header__nav" aria-label="Main navigation">
        <ul>
            <li><a href="/" class="nav-link">Home</a></li>
            <li><a href="/posts" class="nav-link">Posts</a></li>
            <li><a href="/about" class="nav-link">About</a></li>
            <li><a href="/contact" class="nav-link">Contact</a></li>
            <% if (typeof user !== 'undefined' && user) { %>
                <li><a href="<%= user.userType==='admin' ? '/admin/add-post' : '/user/add-post' %>" class="nav-link">+ New post</a></li>
                <li style="margin-left:20px">
                    <span><% if (user.userType==='user') { %>👤 User: <% } %><strong><%= user.username %></strong></span>
                </li>
                <li><a href="/logout" class="nav-link">Logout</a></li>
            <% } else { %>
                <li style="margin-left:20px">
                    <a href="/login-choice" class="nav-link" style="background:#667eea; color:white; padding:8px 15px; border-radius:4px;">Login / Register</a>
                </li>
            <% } %>
        </ul>
    </nav>

    <div class="header_button">
        <button class="themeToggle" id="themeToggle" aria-label="Toggle dark mode">
            <i class="fas fa-moon"></i>
        </button>
        <button class="searchBtn" aria-expanded="false">
            Search 
            <i class="fas fa-search"></i>
        </button>
    </div>

</header>