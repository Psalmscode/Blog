<div class="searchBar">
    <div class="container">
        <form action="/search" method="POST" class="searchForm" role="search">
            <input
             type="search"
             name="searchTerm" 
             id="searchInput" 
             placeholder="Search posts..." 
             aria-label="Search"
             required
             autofocus>
            <button type="submit" class="searchBtn">Search</button>
            <div id="searchClose">Close</div>
        </form>
    </div>
</div>