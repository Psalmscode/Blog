# Environment Variables Configuration

# Database
MONGODB_URI=mongodb://your_mongodb_connection_string
MONGO_URL=mongodb://your_mongodb_connection_string

# Session Secret
SESSION_SECRET=your-session-secret-key-here

# JWT Secret
JWT_SECRET=your-jwt-secret-key-here

# Gmail Configuration (for Contact Form)
# IMPORTANT: Use Gmail App Password, NOT your regular Gmail password
# To create an App Password:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Factor Authentication if not already enabled
# 3. Go to App Passwords (at the bottom of Security settings)
# 4. Select "Mail" and "Windows Computer" (or your device)
# 5. Google will generate a 16-character password - use THIS password below
GMAIL_USER=your-email@gmail.com
GMAIL_PASSWORD=your-16-character-app-password

# Blog Configuration
BLOG_NAME=Node.js Blog
NODE_ENV=development
PORT=5000
